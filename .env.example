# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's already in .gitignore.

# Postgres connection string for the local pgvector-enabled database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_app

# Google Gemini API key, used to call the batchEmbedContents endpoint (gemini-embedding-001,
# truncated to 1536 dimensions) directly via fetch. Free tier, no credit card required.
# Get one at https://aistudio.google.com/api-keys
EMBEDDINGS_API_KEY=your-gemini-key-here

# Anthropic API key, used to call the Messages streaming API directly via fetch.
# Get one at https://console.anthropic.com/settings/keys
LLM_API_KEY=sk-ant-your-anthropic-key-here
