# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's already in .gitignore.

# Postgres connection string for the local pgvector-enabled database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_app

# Google Gemini API key, used to call the batchEmbedContents endpoint (gemini-embedding-001,
# truncated to 1536 dimensions) directly via fetch. Free tier, no credit card required.
# Get one at https://aistudio.google.com/api-keys
EMBEDDINGS_API_KEY=your-gemini-key-here

# Google Gemini API key, used to call the streamGenerateContent endpoint (gemini-3.1-flash-lite)
# directly via fetch. Free tier, no credit card required — the same key as
# EMBEDDINGS_API_KEY works here too, since it's the same provider/account.
# Get one at https://aistudio.google.com/api-keys
LLM_API_KEY=your-gemini-key-here

# Vercel Blob read-write token — used so uploads go browser -> Blob storage
# directly, bypassing Vercel's 4.5MB request body limit. From your Vercel
# project's Storage tab after creating and connecting a Blob store.
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token-here
