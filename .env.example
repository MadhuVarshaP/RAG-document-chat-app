# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's already in .gitignore.

# Postgres connection string for the local pgvector-enabled database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_app

# OpenAI API key, used to call the embeddings endpoint (text-embedding-3-small) directly via fetch.
# Get one at https://platform.openai.com/api-keys
EMBEDDINGS_API_KEY=sk-your-openai-key-here

# Anthropic API key, used to call the Messages streaming API directly via fetch.
# Get one at https://console.anthropic.com/settings/keys
LLM_API_KEY=sk-ant-your-anthropic-key-here
